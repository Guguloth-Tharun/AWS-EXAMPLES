echo "Delete Bucket"

if [ -z "$1" ]; then
   echo " Specify the bucket name to be deleted "
fi

BUCKET_NAME="$1"

read -p  "Are you sure you want to delete '$BUCKET_NAME' ? (y/n): " CONFIRM

if [ "$CONFIRM" = "y" ] || [ "$CONFIRM" = "Y" ]; then
   echo "$BUCKET_NAME is going to be deleted"
   
   aws s3api delete-bucket \
   --bucket $BUCKET_NAME

else 
    echo " Deletion Cancelled "
    exit 0
fi




